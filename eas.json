{
  "cli": {
    "version": ">= 16.4.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://food-scanner-ai-backend-production.up.railway.app",
        "EXPO_PUBLIC_API_VERSION": "v1",
        "EXPO_PUBLIC_ENABLE_BACKEND_LOGGING": "true"
      }
    },
    "preview": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://food-scanner-ai-backend-production.up.railway.app",
        "EXPO_PUBLIC_API_VERSION": "v1",
        "EXPO_PUBLIC_ENABLE_BACKEND_LOGGING": "true"
      }
    },
    "internal": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://food-scanner-ai-backend-production.up.railway.app",
        "EXPO_PUBLIC_API_VERSION": "v1",
        "EXPO_PUBLIC_ENABLE_BACKEND_LOGGING": "true"
      },
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      }
    },
    "e2e-test": {
      "distribution": "internal",
      "withoutCredentials": true,
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://food-scanner-ai-backend-production.up.railway.app",
        "EXPO_PUBLIC_API_VERSION": "v1",
        "EXPO_PUBLIC_ENABLE_BACKEND_LOGGING": "true",
        "E2E": "true",
        "E2E_MOCK_CHAT_REPLY": "E2E_MOCK_CHAT_REPLY: Keep hydration and protein consistent every day."
      },
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true
      }
    },
    "production": {
      "distribution": "store",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://food-scanner-ai-backend-production.up.railway.app",
        "EXPO_PUBLIC_API_VERSION": "v1",
        "EXPO_PUBLIC_ENABLE_BACKEND_LOGGING": "true"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "simulator": false
      }
    }
  },
  "submit": {
    "production": {}
  }
}
