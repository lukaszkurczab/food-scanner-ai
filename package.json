{
  "name": "fitaly",
  "version": "1.0.1",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "main": "index.ts",
  "scripts": {
    "dev": "npx expo start --dev-client",
    "start": "npx expo start",
    "android": "npx expo run:android",
    "ios": "npx expo run:ios",
    "prod:test": "npx expo start --no-dev --minify",
    "lint": "eslint src --ext .ts,.tsx,.js,.jsx",
    "tsc": "tsc",
    "typecheck": "tsc --noEmit",
    "check:launch-readiness:android": "node scripts/check-launch-readiness.mjs production android",
    "check:launch-readiness:ios": "node scripts/check-launch-readiness.mjs production ios",
    "publish:android": "READINESS_ASSUME_EAS_SECRETS=true npm run check:launch-readiness:android && npx eas-cli@18.6.0 build -p android --profile production",
    "publish:ios": "READINESS_ASSUME_EAS_SECRETS=true npm run check:launch-readiness:ios && npx eas-cli@18.6.0 build -p ios --profile production",
    "build:android": "npm run check:launch-readiness:android && node scripts/build.js android production",
    "build:ios": "npm run check:launch-readiness:ios && node scripts/build.js ios production",
    "build:android:smoke": "node scripts/build.js android smoke",
    "build:ios:smoke": "node scripts/build.js ios smoke",
    "eas:android:smoke": "npx eas-cli@18.6.0 build -p android --profile smoke",
    "eas:ios:smoke": "npx eas-cli@18.6.0 build -p ios --profile smoke",
    "fonts:download": "node scripts/download-fonts.mjs",
    "test": "jest --runInBand --coverage --watchman=false",
    "test:targeted": "jest --config jest.targeted.config.js --runInBand --watchman=false --passWithNoTests",
    "test:reminders": "jest --runInBand --watchman=false --no-coverage --testPathPatterns='src/services/reminders/|src/__contract_fixtures__/contractAlignment'",
    "test:reminders:watch": "jest --watchman=false --watch --no-coverage --testPathPatterns='src/services/reminders/|src/__contract_fixtures__/contractAlignment'",
    "test:coverage:slice": "jest --runInBand --coverage --watchman=false --passWithNoTests",
    "e2e": "bash scripts/run-e2e-local.sh e2e/maestro",
    "e2e:foundation": "bash scripts/run-e2e-local.sh e2e/maestro/foundation-smoke.yaml",
    "e2e:login": "bash scripts/run-e2e-local.sh e2e/maestro/login.yaml",
    "e2e:auth-bootstrap": "bash scripts/run-e2e-local.sh e2e/maestro/auth-bootstrap.yaml",
    "e2e:register-conflict": "bash scripts/run-e2e-local.sh e2e/maestro/register-conflict.yaml",
    "e2e:add-meal": "bash scripts/run-e2e-local.sh e2e/maestro/add-meal.yaml",
    "e2e:chat-ai": "bash scripts/run-e2e-local.sh e2e/maestro/chat-ai.yaml",
    "e2e:offline-error": "bash scripts/run-e2e-local.sh e2e/maestro/offline-error.yaml"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-community/netinfo": "11.5.2",
    "@react-native-community/slider": "5.2.0",
    "@react-native-firebase/app": "^24.0.0",
    "@react-native-firebase/auth": "^24.0.0",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "7.14.11",
    "@react-navigation/stack": "7.8.10",
    "@sentry/react-native": "~7.13.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.6.1",
    "expo": "^55.0.15",
    "expo-asset": "~55.0.15",
    "expo-background-task": "~55.0.16",
    "expo-build-properties": "~55.0.13",
    "expo-camera": "~55.0.15",
    "expo-constants": "~55.0.14",
    "expo-dev-client": "~55.0.27",
    "expo-device": "~55.0.15",
    "expo-file-system": "~55.0.16",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.14",
    "expo-image-manipulator": "~55.0.15",
    "expo-image-picker": "~55.0.18",
    "expo-localization": "~55.0.13",
    "expo-media-library": "~55.0.14",
    "expo-notifications": "~55.0.19",
    "expo-print": "~55.0.13",
    "expo-secure-store": "~55.0.13",
    "expo-sharing": "~55.0.18",
    "expo-splash-screen": "~55.0.18",
    "expo-sqlite": "~55.0.15",
    "expo-status-bar": "~55.0.5",
    "expo-task-manager": "~55.0.14",
    "i": "^0.3.7",
    "i18next": "^25.3.2",
    "react": "19.2.0",
    "react-i18next": "^15.6.0",
    "react-native": "0.83.6",
    "react-native-color-wheel": "^0.1.7",
    "react-native-device-info": "^14.0.4",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-get-random-values": "~1.11.0",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-purchases": "^9.1.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-view-shot": "4.0.3",
    "react-native-worklets": "0.7.2",
    "react-native-zip-archive": "^7.0.2",
    "reanimated-color-picker": "^4.1.1",
    "uuid": "11.1.0"
  },
  "devDependencies": {
    "@babel/core": "7.26.10",
    "@react-native-community/cli": "^18.0.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/date-fns": "^2.5.3",
    "@types/jest": "29.5.14",
    "@types/lodash": "^4.17.20",
    "@types/lodash.debounce": "^4.0.9",
    "@types/react": "~19.2.10",
    "@types/react-test-renderer": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "adm-zip": "^0.5.16",
    "babel-jest": "^30.0.4",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-expo": "^55.0.18",
    "eslint": "^8.57.1",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "identity-obj-proxy": "^3.0.0",
    "jest": "~29.7.0",
    "react-native-svg-transformer": "^1.5.3",
    "react-test-renderer": "19.2.0",
    "typescript": "5.9.3"
  },
  "overrides": {
    "expo-dev-launcher": {
      "ajv": "8.18.0"
    },
    "fast-xml-parser": "5.5.10",
    "protobufjs": "7.5.5"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false,
        "exclude": [
          "react-native-zip-archive"
        ]
      }
    }
  },
  "private": true
}
