# Backend routing by environment:
# local       -> http://localhost:8000/
# dev/smoke   -> https://fitaly-backend-smoke.up.railway.app
# production  -> https://fitaly-backend-production.up.railway.app
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000/
EXPO_PUBLIC_API_VERSION=v1
EXPO_PUBLIC_ENABLE_BACKEND_LOGGING=true

# Runtime flags
EXPO_PUBLIC_ENABLE_TELEMETRY=false

# RevenueCat
RC_IOS_API_KEY=
RC_ANDROID_API_KEY=

# Legal links (required for production readiness checks)
TERMS_URL=https://lkurczab.netlify.app/fitaly/terms
PRIVACY_URL=https://lkurczab.netlify.app/fitaly/privacy

# Runtime toggles
DEBUG_OCR=false
DISABLE_BILLING=false
FORCE_PREMIUM=false

# Used only by scripts/download-fonts.mjs
GOOGLE_FONTS_KEY=
